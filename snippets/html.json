{
  "svguse": {
    "scope": "html",
    "prefix": "g-use",
    "body": [
      "<svg class=\"\">",
      "  <use xlink:href=\"img/sprite.svg#$2\"></use>",
      "</svg>"
    ],
    "description": "Snippet for use svg sprites"
  },
  "burger": {
    "scope": "html",
    "prefix": "g-burger",
    "body": [
      "<button class=\"burger\" aria-label=\"Открыть меню\" aria-expanded=\"false\"  data-burger>",
      "  <span class=\"burger__line\"></span>",
      "</button>"
    ],
    "description": "Snippet for burger btn"
  },
  "navigation": {
    "scope": "html",
    "prefix": "g-nav",
    "body": [
      "<nav class=\"nav\" title=\"$1\">",
      "  <ul class=\"nav__list\">",
      "    <li class=\"nav__item\"><a href=\"#\" class=\"nav__link\"></a></li>",
      "    <li class=\"nav__item\"><a href=\"#\" class=\"nav__link\"></a></li>",
      "    <li class=\"nav__item\"><a href=\"#\" class=\"nav__link\"></a></li>",
      "  </ul>",
      "</nav>"
    ],
    "description": "Snippet for navigation"
  },
  "social": {
    "scope": "html",
    "prefix": "g-social",
    "body": [
      "<ul class=\"social\" title=\"$1\">",
      "  <li class=\"social__item\"><a href=\"#\" target=\"_blank\" class=\"social__link social__link--fb\" aria-label=\"Наша страничка в Фейсбуке\"></a></li>",
      "  <li class=\"social__item\"><a href=\"#\" target=\"_blank\" class=\"social__link social__link--vk\" aria-label=\"Наша страничка во Вконтакте\"></a></li>",
      "  <li class=\"social__item\"><a href=\"#\" target=\"_blank\" class=\"social__link social__link--tw\" aria-label=\"Наша страничка в Твиттере\"></a></li>",
      "</ul>"
    ],
    "description": "Snippet for social links"
  },
  "basicform": {
    "prefix": "g-form",
    "body": [
      "<form action=\"#\" class=\"form\">",
      "  <label class=\"form__label\">",
      "    <input type=\"text\" name=\"Имя\" class=\"input-reset form__input\" placeholder=\"Имя\">",
      "  </label>",
      "  <button class=\"btn-reset form__btn\">Отправить</button>",
      "</form>"
    ],
    "description": "Snippet for basic form"
  },
  "basicswiper": {
    "prefix": "g-swiper",
    "body": [
      "<div class=\"swiper $1\">",
      "  <div class=\"swiper-wrapper\">",
      "     <div class=\"swiper-slide\">",
      "     </div>",
      "  </div>",
      "</div>"
    ],
    "description": "Snippet for basic swiper structure"
  },
  "graph modal Btn": {
    "prefix": "g-graph-btn",
    "body": [
      "<button class=\"$1\" data-graph-path=\"$2\">$3</button>"
    ],
    "description": "Snippet for graph-modal btn"
  },
  "graph modal Structure": {
    "prefix": "g-graph-modal",
    "body": [
      "<div class=\"graph-modal\">",
      "  <div class=\"graph-modal__container\" role=\"dialog\" aria-modal=\"true\" data-graph-target=\"$1\">",
      "    <button class=\"btn-reset js-modal-close graph-modal__close\" aria-label=\"Закрыть модальное окно\"></button>",
      "    <div class=\"graph-modal__content\">$2</div>",
      "  </div>",
      "</div>"
    ],
    "description": "Snippet for graph-modal basic structure"
  },
  "picture": {
    "prefix": "g-picture",
    "body": [
      "<picture>",
      "  <source srcset=\"$1.avif\" type=\"image/avif\">",
      "  <source srcset=\"$1.webp\" type=\"image/webp\">",
      "  <img loading=\"lazy\" src=\"$1.$2\" class=\"image\" width=\"$4\" height=\"$5\" alt=\"$3\">",
      "</picture>"
    ],
    "description": "Snippet for basic logo structure"
  },
  "svgimg": {
    "scope": "html",
    "prefix": "g-svgimg",
    "body": [
      "<img loading=\"lazy\" src=\"$1.$2\" class=\"image\" width=\"$4\" height=\"$5\" alt=\"$3\">"
    ],
    "description": "Snippet for simple html svg images"
  },
  "tooltip": {
  "prefix": "g-tooltip",
    "body": [
      "<div class=\"tooltip\">",
      "  <button class=\"tooltip__btn btn btn-reset\" aria-describedby=\"$1\">Описание</button>",
      "  <span class=\"tooltip__content\" role=\"tooltip\" id=\"$1\">",
      "    <span class=\"visually-hidden\">Тултип: </span>",
      "    descr",
      "  </span>",
      "</div>"
    ],
    "description": "Snippet for tooltip"
  },
  "tabs html sctructure": {
    "prefix": "g-tabs",
    "body": [
      "<div class=\"tabs\" data-tabs=\"$1\">",
      "  <ul class=\"tabs__nav\">",
      "    <li class=\"tabs__nav-item list-reset\"><button class=\"tabs__nav-btn btn-reset\" type=\"button\">$2</button></li>",
      "    <li class=\"tabs__nav-item list-reset\"><button class=\"tabs__nav-btn btn-reset\" type=\"button\">$3</button></li>",
      "    <li class=\"tabs__nav-item list-reset\"><button class=\"tabs__nav-btn btn-reset\" type=\"button\">$4</button></li>",
      "  </ul>",
      "  <div class=\"tabs__content\">",
      "    <div class=\"tabs__panel\">$5</div>",
      "    <div class=\"tabs__panel\">$6</div>",
      "    <div class=\"tabs__panel\">$7</div>",
      "  </div>",
      "</div>"
    ],
    "description": "Snippet for basic tabs structure"
  },
  "Spollers": {
		"prefix": "spollers",
		"body": [
      "<ul data-spollers data-one-spoller class=\"spollers__list list-reset\">",
      "  <li class=\"spollers__item\">",
      "    <button tabindex=\"-1\" type=\"button\" data-spoller class=\"spollers__title\">Аккордеон 1</button>",
      "    <div class=\"spollers__content\">descr</div>",
      "  </li>",
      "</ul>"
		],
		"description": "Добавляет базовый HTML код спойлеров"
	},
  "Add container": {
		"prefix": "cnt",
		"body": "<div class=\"container\">\n\t$1\n</div>",
		"description": "Добавляет ограничивающий контейнер"
	},
  "simplebar": {
		"scope": "html",
		"prefix": "simplebar",
		"body": "<div class=\"scrollbar\" data-simplebar>\n\t$2\n</div>",
		"description":  "Добавляет базовый HTML код simplebar",
	},
  "gallery": {
		"scope": "html",
		"prefix": "gallery",
    "body": [
      "<div id=\"$1\">",
      "  <a href=\"img/\">",
      "     <img src=\"img/\" alt=\"img\">",
      "  </a>",
      "  <a href=\"img/\">",
      "     <img src=\"img/\" alt=\"img\">",
      "  </a>",
      "</div>"
    ],
		"description": "Добавляет базовый HTML код галереи"
	},
  "Rating": {
		"scope": "html",
		"prefix": "rating",
		"body": [
			"<div class=\"rating rating_set\">\n\t<div class=\"rating__body\">\n\t\t<div class=\"rating__active\"></div>\n\t\t<div class=\"rating__items\">\n\t\t\t<input type=\"radio\" class=\"rating__item\" value=\"1\" name=\"rating\">\n\t\t\t<input type=\"radio\" class=\"rating__item\" value=\"2\" name=\"rating\">\n\t\t\t<input type=\"radio\" class=\"rating__item\" value=\"3\" name=\"rating\">\n\t\t\t<input type=\"radio\" class=\"rating__item\" value=\"4\" name=\"rating\">\n\t\t\t<input type=\"radio\" class=\"rating__item\" value=\"5\" name=\"rating\">\n\t\t</div>\n\t</div>\n\t<div class=\"rating__value\">3.6</div>\n</div>"
		],
		"description": "Добавляет базовый HTML код рейтинга"
	},

  "Add input tag": {
		"scope": "html",
		"prefix": "inp",
		"body": "<input type=\"text\" class=\"input-reset\" placeholder=\"$1\">",
		"description": "Добавляет input со настройками"
	},
  "Textarea": {
		"scope": "html,kit",
		"prefix": "textarea",
		"body": "<textarea class=\"input\" placeholder=\"$1\"></textarea>",
		"description": "snipper for textarea"
	},
  "checkbox": {
    "scope": "html",
    "prefix": "g-checkbox",
    "body": [
      "<label class=\"custom-checkbox\">",
      "  <input type=\"checkbox\" class=\"custom-checkbox__field\">",
      "  <span class=\"custom-checkbox__content\">$1</span>",
      "</label>"
    ],
    "description": "Snippet for custom checkbox"
  },
  "Button": {
		"prefix": "btn",
		"body": "<button type=\"submit\" class=\"btn btn-reset\">${1:Отправить}</button>",
		"description": "snipper for btn"
	},
  "qa": {
		"scope": "html,kit",
		"prefix": "qa",
		"body": [
      "<div class=\"quantity\">",
      "   <div class=\"quantity__button quantity__button_plus\"></div>",
      "   <div class=\"quantity__input\">",
      "       <input type=\"text\" value=\"1\">",
      "   </div>",
      "   <div class=\"quantity__button quantity__button_minus\"></div>",
      "</div>",
    ],
    "description": "qa"
	},
  "radio": {
		"prefix": "opt",
		"body": "<div class=\"options\">\n\t<div class=\"options__item\">\n\t\t<input hidden id=\"o_1\" class=\"options__input\" checked type=\"radio\" value=\"1\" name=\"option\">\n\t\t<label for=\"o_1\" class=\"options__label\"><span class=\"options__text\">${1:Текст}</span></label>\n\t</div>\n\t<div class=\"options__item\">\n\t\t<input hidden id=\"o_2\" class=\"options__input\" type=\"radio\" value=\"2\" name=\"option\">\n\t\t<label for=\"o_2\" class=\"options__label\"><span class=\"options__text\">${2:Текст}</span></label>\n\t</div>\n</div>",
		"description": "radio"
	},
  "Add image IBG": {
		"scope": "html",
		"prefix": "ibg",
		"body": [
			"<div class=\"${1:имя блока}__image-ibg\"><img src=\"@img$2\" alt=\"\"></div>"
		],
		"description": "Добавляет объект с картинкой и классом IBG"
	},
	"Add Link with image IBG": {
		"scope": "html",
		"prefix": "ibga",
		"body": [
			"<a href=\"\" class=\"${1:имя блока}__image-ibg\"><img src=\"@img$2\" alt=\"\"></a>"
		],
		"description": "Добавляет ссылку с картинкой и классом IBG"
	},
}



